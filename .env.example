# ===== Yasmine Kost — Environment Variables =====
# Salin file ini menjadi .env lalu sesuaikan nilainya.

# Database (SQLite untuk pengembangan/rilis pertama).
# Untuk PostgreSQL, ganti provider di prisma/schema.prisma dan gunakan:
# DATABASE_URL="postgresql://user:password@localhost:5432/yasmine?schema=public"
DATABASE_URL="file:./dev.db"

# Secret untuk menandatangani sesi login admin (JWT cookie).
# WAJIB diganti dengan string acak panjang di produksi, mis. hasil dari:
#   openssl rand -base64 32
AUTH_SECRET="ubah-ini-dengan-string-acak-yang-panjang-dan-rahasia"

# Akun admin awal yang dibuat oleh `npm run db:seed`.
ADMIN_NAME="Pemilik Yasmine Kost"
ADMIN_EMAIL="admin@yasminekost.com"
ADMIN_PASSWORD="admin12345"

# Folder penyimpanan file upload (foto kamar & bukti transfer).
# Di VPS arahkan ke volume yang ikut di-backup, mis. /var/www/yasmine/uploads
UPLOAD_DIR="./uploads"

# URL publik situs (untuk metadata/SEO & sitemap).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
